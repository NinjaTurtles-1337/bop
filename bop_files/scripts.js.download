$(function(){$("li:first-child").addClass("first");$("li:last-child").addClass("last");$('.bop-menu').superfish({animation:{opacity:'show',height:'show'},autoArrows:false,dropShadows:false,});$('.global_tab_inner .tab-content >div:first-child').addClass("in");$('.global_tab_inner .tab-content >div').addClass("fade");$('table tr:first-child').addClass('first');$('tr').filter(function(){return $(this).find('td').length==$(this).find('td:empty').length;}).hide();var slider=$('#home_slide > ul').bxSlider({auto:true,autoStart:true,useCSS:false,adaptiveHeight:true,pager:true,captions:true,infiniteLoop:true,mode:'fade',onSliderLoad:function(){$('.bx-pager-link').click(function(){var i=$(this).data('slide-index');slider.goToSlide(i);slider.stopAuto();slider.startAuto();return false;});}});$('#highlights').bxSlider({auto:true,useCSS:false,adaptiveHeight:true,pager:false,speed:800,captions:false,pause:5000,mode:'fade'});$("#thumb_slider").owlCarousel({navigation:true,items:3,itemsDesktop:[1199,3],itemsDesktopSmall:[979,3],navigation:true,itemsScaleUp:true});$('#conventional_radio').click(function(){$('#islamic_ibn').hide();$('#conventional_ibn').fadeIn();});$('#islamic_radio').click(function(){$('#islamic_ibn').fadeIn();$('#conventional_ibn').hide();});$('.notification_bar .notif_close').click(function(){$('.notification_bar').hide();});if($("#User_Guide_Main").length>0){var realSlider=$("#User_Guide_Main ul").bxSlider({pager:false,nextText:'',useCSS:false,adaptiveHeight:true,prevText:'',infiniteLoop:false,hideControlOnEnd:true,onSlideBefore:function($slideElement,oldIndex,newIndex){changeRealDetailThumb(realThumbSlider,newIndex);}});var realThumbSlider=$("#User_Guide_Thumb ul").bxSlider({minSlides:6,maxSlides:6,slideWidth:101,slideMargin:7,moveSlides:1,pager:false,speed:1000,infiniteLoop:false,hideControlOnEnd:true,nextText:'<span></span>',prevText:'<span></span>',onSlideBefore:function($slideElement,oldIndex,newIndex){}});linkRealSliders(realSlider,realThumbSlider);if($("#User_Guide_Thumb li").length<7){$("#User_Guide_Thumb .bx-next").hide();}}
function linkRealSliders(bigS,thumbS){$("#User_Guide_Thumb ul").on("click","a",function(event){event.preventDefault();newIndex=$(this).parent().attr("slideIndex");bigS.goToSlide(newIndex);});}
function changeRealDetailThumb(slider,newIndex){var $thumbS=$("#User_Guide_Thumb");$thumbS.find('.active').removeClass("active");$thumbS.find('li[slideIndex="'+newIndex+'"]').addClass("active");if(slider.getSlideCount()-newIndex>=6)slider.goToSlide(newIndex);else slider.goToSlide(slider.getSlideCount()-6);}
$('.collapse').on('shown.bs.collapse',function(){jQuery(this).parent().find(".panel-heading").addClass("active-panel");}).on('hidden.bs.collapse',function(){$(this).parent().find(".panel-heading").removeClass("active-panel");});$('.panel-collapse.in').collapse('hide');$('.media_slide').owlCarousel({navigation:true,items:3,itemsDesktop:[1199,3],itemsDesktopSmall:[979,3],navigation:true});$('.print_slide').owlCarousel({navigation:true,items:4,itemsDesktop:[1199,3],itemsDesktopSmall:[979,4],itemsTablet:[768,3],navigation:true});$('header.header .top_links > ul > li.search_form').on('click',function(e){$(this).find('ul').fadeToggle();e.stopPropagation();});$('header.header .top_links > ul > li.search_form ul').on('click',function(e){e.stopPropagation();});$("body").bind("click",function(){$('header.header .top_links > ul > li.search_form ul').hide();});sticky_navigation();$(window).scroll(function(){sticky_navigation();});});$(window).resize(function(){$('.home_wrapper').css({position:'absolute',left:($(window).width()-$('.home_wrapper').outerWidth())/2,top:($(window).height()-$('.home_wrapper').outerHeight())/2});});$(window).resize();$(window).load(function(){$('.side_nav > ul > li.current_page_parent > ul ').css({'display':'block'});$('.notification_bar').slideDown();});function findTotalOffset(obj){var oleft=otop=0;if(obj.offsetParent){do{oleft+=obj.offsetLeft;otop+=obj.offsetTop;}while(obj=obj.offsetParent);}
return{left:oleft,top:otop};};var sticky_navigation_offset_top=findTotalOffset($('header.header')).top;var sticky_navigation=function(){var scroll_top=$(window).scrollTop();if(scroll_top>sticky_navigation_offset_top){$('header.header').addClass('sticky');}else{$('header.header').removeClass('sticky');}};$(function(){$(".products").bootstrapNews({newsPerPage:1,navigation:true,autoplay:true,direction:'up',animationSpeed:'normal',newsTickerInterval:2000,pauseOnHover:true,onStop:null,onPause:null,onReset:null,onPrev:null,onNext:null,onToDo:null});});jQuery(document).ready(function($){$('#menu').slicknav({prependTo:'#empty_div'});});jQuery(document).ready(function($){$("ul#ticker01").liScroll().li;});$(window).load(function(){$("[data-toggle=popover]").popover({html:true,content:function(){return $('#popover-content').html();},placement:function(){if(screen.width<400)return'top';else return'right';}});});$(window).load(function(){$("[data-toggle=popover1]").popover({html:true,content:function(){return $('#popover-content1').html();},placement:function(){if(screen.width<400)return'top';else return'right';}});});function validateDecimal(input){input.value=input.value.replace(/[^0-9.]/g,'');const parts=input.value.split('.');if(parts.length>2){input.value=parts[0]+'.'+parts.slice(1).join('');}}
$(document).ready(function(){$('#txtCNIC').data('holder',$('#txtCNIC').attr('placeholder'));$('#txtCNIC').focusin(function(){$(this).attr('placeholder','');});$('#txtCNIC').focusout(function(){$(this).attr('placeholder',$(this).data('holder'));});$('#txtCNIC').on('input',function(){let value=$(this).val().replace(/\D/g,'');if(value.length>5){value=value.slice(0,5)+'-'+value.slice(5);}
if(value.length>13){value=value.slice(0,13)+'-'+value.slice(13);}
$(this).val(value);const length=value.length;if(length===5||length===11){$(this).get(0).setSelectionRange(length+1,length+1);}else{$(this).get(0).setSelectionRange(length,length);}});});